                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="배정 완료" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" Cursor="Hand" Click="BtnConfirmStudentSelect_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ================= APPROVAL HISTORY MODAL ================= -->
        <Grid x:Name="ModalApprovalHistory" Grid.ColumnSpan="2" Background="#90000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="White" Width="650" Height="600" CornerRadius="12" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="승인 및 반려 내역" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                        <Button Content="✕" FontSize="16" FontWeight="Bold" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Click="BtnCloseApprovalHistory_Click"/>
                    </Grid>
                    
                    <!-- List -->
                    <DataGrid Grid.Row="1" x:Name="GridApprovalHistoryList" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="35" BorderThickness="0" Background="Transparent" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="이름" Binding="{Binding StudentName}" Width="80"/>
                            <DataGridTextColumn Header="학번" Binding="{Binding StudentId}" Width="100"/>
                            <DataGridTextColumn Header="구분" Binding="{Binding TabType}" Width="80"/>
                            <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="일시" Binding="{Binding RequestDate, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Footer Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="닫기" Background="#F3F4F6" Foreground="#374151" BorderThickness="0" Padding="15,8" Margin="0,0,8,0" FontWeight="Bold" Cursor="Hand" Click="BtnCloseApprovalHistory_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="대기목록에 다시 추가" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" Cursor="Hand" Click="BtnReAddApproval_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ================= RENTAL HISTORY MODAL ================= -->
        <Grid x:Name="ModalRentalHistory" Grid.ColumnSpan="2" Background="#90000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="White" Width="650" Height="600" CornerRadius="12" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="기자재 대여 및 반납 전체 내역" FontSize="16" FontWeight="Bold" Foreground="#111827"/>
                        <Button Content="✕" FontSize="16" FontWeight="Bold" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right" Click="BtnCloseRentalHistory_Click"/>
                    </Grid>
                    
                    <!-- List -->
                    <DataGrid Grid.Row="1" x:Name="GridRentalHistoryList" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="35" BorderThickness="0" Background="Transparent" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="대여자" Binding="{Binding StudentName}" Width="80"/>
                            <DataGridTextColumn Header="기자재명" Binding="{Binding EquipmentType}" Width="180"/>
                            <DataGridTextColumn Header="대여일" Binding="{Binding RentalDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTextColumn Header="반납예정일" Binding="{Binding DueDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                            <DataGridTextColumn Header="상태" Binding="{Binding StatusDisplay}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Footer Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="닫기" Background="#6B7280" Foreground="White" BorderThickness="0" Padding="20,8" FontWeight="Bold" Cursor="Hand" Click="BtnCloseRentalHistory_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <!-- ================= CABINET DETAIL MODAL OVERLAY ================= -->
        <Grid x:Name="ModalCabinetDetails" Grid.ColumnSpan="2" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="White" Width="600" Height="400" CornerRadius="20" Padding="35" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="Black" Opacity="0.25"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-15,0,0">
                        <Button x:Name="BtnEditCabinetInfo" Content="정보 수정" Background="#F3F4F6" Foreground="#374151" BorderThickness="0" Padding="15,6" FontSize="12" FontWeight="SemiBold" Cursor="Hand" Click="BtnEditCabinetInfo_Click" Margin="0,0,15,0">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="BtnCloseCabinetModal" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnCloseCabinetModal_Click" Padding="5">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#111827"/>
                        </Button>
                    </StackPanel>

                    <!-- Title -->
                    <TextBlock x:Name="TxtCabinetModalTitle" Text="캐비닛 00번 상세 정보" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

                    <!-- Fields -->
                    <Grid Grid.Row="1" Margin="10,0,10,0" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Name -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="이름 : " FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,15"/>
                        <TextBox x:Name="TxtCabinetModalName" Grid.Row="0" Grid.Column="1" FontSize="22" FontWeight="Bold" Foreground="#111827" Background="Transparent" BorderThickness="0" IsReadOnly="True" Margin="0,0,0,15"/>

                        <!-- ID -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="학번 : " FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,15"/>
                        <TextBox x:Name="TxtCabinetModalId" Grid.Row="1" Grid.Column="1" FontSize="22" FontWeight="Bold" Foreground="#111827" Background="Transparent" BorderThickness="0" IsReadOnly="True" Margin="0,0,0,15"/>

                        <!-- Period -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="대여 기간 : " FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                        <TextBox x:Name="TxtCabinetModalPeriod" Grid.Row="2" Grid.Column="1" FontSize="22" FontWeight="Bold" Foreground="#111827" Background="Transparent" BorderThickness="0" IsReadOnly="True"/>
                    </Grid>

                    <!-- Save Button (Only visible during edit) -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button x:Name="BtnSaveCabinetModal" Content="저장" Visibility="Collapsed" Background="#10B981" Foreground="White" BorderThickness="0" Padding="20,8" FontWeight="Bold" Cursor="Hand" Click="BtnSaveCabinetModal_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ================= LOADING OVERLAY ================= -->
        <Grid x:Name="ModalLoading" Grid.ColumnSpan="2" Background="#70000000" Visibility="Collapsed" Panel.ZIndex="200">
            <Border Background="White" Width="300" Height="150" CornerRadius="12" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="↻" FontSize="36" Foreground="#2563EB" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerTransform" Angle="0"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SpinnerTransform" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="구글 폼 데이터 동기화 중..." FontSize="14" FontWeight="Bold" Foreground="#374151" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
