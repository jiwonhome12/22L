<Window x:Class="SeatManagerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="동서대학교 좌석 및 기자재 관리 시스템" Height="780" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F3F4F6"
        MinHeight="720" MinWidth="1100">

    <Window.Resources> 
        <!-- Modern Scrollbar Style -->
        <Style TargetType="ScrollBar">
            <!-- Simplified standard styling for scrollbars -->
        </Style>

        <!-- Base Button Styles -->
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderThickness="4,0,0,0" BorderBrush="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#111827"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarBtnActive" TargetType="Button" BasedOn="{StaticResource SidebarBtn}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderThickness="4,0,0,0" BorderBrush="#60A5FA" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Top Bar Action Button -->
        <Style x:Key="ActionBarBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Seat Card Style -->
        <Style x:Key="SeatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar Menu -->
            <ColumnDefinition Width="220"/>
            <!-- Main Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= SIDEBAR ================= -->
        <Grid Grid.Column="0" Background="#0A1C3E">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Logo Area -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                <TextBlock Text="DSU" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text=" 동서대학교" Foreground="#93C5FD" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,3,0,0"/>
            </StackPanel>

            <!-- Sidebar Buttons -->
            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                <Button x:Name="BtnDashboard" Content="🏠 대시보드" Style="{StaticResource SidebarBtnActive}" Click="BtnDashboard_Click"/>
                <Button x:Name="BtnEquipment" Content="🔧 기자재 현황" Style="{StaticResource SidebarBtn}" Click="BtnEquipment_Click"/>
                <Button x:Name="BtnCabinet" Content="🗄️ 캐비닛 현황" Style="{StaticResource SidebarBtn}" Click="BtnCabinet_Click"/>
                <Button x:Name="BtnSangsangLab" Content="💡 상상Lab 승인" Style="{StaticResource SidebarBtn}" Click="BtnSangsangLab_Click"/>
                <Button x:Name="BtnDataManage" Content="📊 데이터 관리" Style="{StaticResource SidebarBtn}" Click="BtnDataManage_Click"/>
                <Button x:Name="BtnSettings" Content="⚙️ 설정" Style="{StaticResource SidebarBtn}" Click="BtnSettings_Click"/>
            </StackPanel>
        </Grid>

        <!-- ================= MAIN AREA ================= -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Top Header -->
                <RowDefinition Height="75"/>
                <!-- Tab Workspace Content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP HEADER -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Section Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHeaderTitle" Text="대시보드" FontSize="18" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Alert / Status Badges (Only relevant for Dashboard) -->
                    <StackPanel x:Name="HeaderAlertArea" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0">
                        <!-- SangsangLab Approval Alert Card -->
                        <Border Background="#FEE2E2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8" Padding="12,6" Margin="0,0,12,0" Cursor="Hand" MouseDown="AlertSangsangLab_MouseDown">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="💡" FontSize="18" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="상상Lab 승인 대기" FontSize="10" Foreground="#991B1B" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtSangsangLabCount" Text="0건" FontSize="12" Foreground="#DC2626" FontWeight="Bold"/>
                                    <TextBlock Text="승인 필요" FontSize="9" Foreground="#991B1B"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Cabinet Approval Alert Card -->
                        <Border Background="#FFEDD5" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="8" Padding="12,6" Margin="0,0,12,0" Cursor="Hand" MouseDown="AlertCabinet_MouseDown">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🗄️" FontSize="18" Foreground="#EA580C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="캐비닛" FontSize="10" Foreground="#9A3412" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtCabinetCount" Text="0건" FontSize="12" Foreground="#EA580C" FontWeight="Bold"/>
                                    <TextBlock Text="승인 필요" FontSize="9" Foreground="#9A3412"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Equipment Return Alert Card -->
                        <Border Background="#FEE2E2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8" Padding="12,6" Cursor="Hand" MouseDown="AlertEquipment_MouseDown">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔧" FontSize="18" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="기자재" FontSize="10" Foreground="#991B1B" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtEquipmentCount" Text="0건" FontSize="12" Foreground="#DC2626" FontWeight="Bold"/>
                                    <TextBlock Text="반납 필요" FontSize="9" Foreground="#991B1B"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Profile & DateTime -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Profile Card -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                            <TextBlock Text="👤" FontSize="16" Foreground="#4B5563" Margin="0,0,5,0"/>
                            <TextBlock Text="관리자" FontSize="13" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"/>
                            <TextBlock Text=" ∨" FontSize="10" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Date Display -->
                        <Border Background="#F3F4F6" Padding="10,6" CornerRadius="6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅 " FontSize="12" Foreground="#4B5563"/>
                                <TextBlock x:Name="TxtCurrentDate" Text="2026-07-16 (목)" FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- WORKSPACE TABS CONTAINER -->
            <Grid Grid.Row="1">
                <!-- ================= TAB 1: DASHBOARD ================= -->
                <Grid x:Name="TabDashboard" Visibility="Visible" Background="#F9FAFB">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="15">
                        <Grid.RowDefinitions>
                            <!-- Search & Action Controls -->
                            <RowDefinition Height="Auto"/>
                            <!-- Seat Grid ScrollViewer -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Control & Filter Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Year/Semester Search Panel -->
                            <Border Grid.Column="0" Background="#1F2937" CornerRadius="6" Padding="15,10" VerticalAlignment="Center" Margin="0,0,15,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="년도" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="ComboSearchYear" Width="100" Padding="5" SelectedIndex="0"/>

                                    <TextBlock Text="학기" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="25,0,8,0"/>
                                    <ComboBox x:Name="ComboSearchSemester" Width="120" Padding="5" SelectedIndex="0">
                                        <ComboBoxItem Content="1학기"/>
                                        <ComboBoxItem Content="여름방학"/>
                                        <ComboBoxItem Content="2학기"/>
                                        <ComboBoxItem Content="겨울방학"/>
                                    </ComboBox>

                                    <Button Content="🔍 조회" Background="#111827" Foreground="White" BorderThickness="0" 
                                            FontWeight="Bold" Padding="15,6" Margin="20,0,0,0" Cursor="Hand" Click="BtnSearch_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Action Buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BtnRefresh" Content="🔄" Width="35" Height="35" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnRefresh_Click"/>
                                <Button x:Name="BtnSyncData" Content="데이터 동기화" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnSyncData_Click"/>
                                <Button Content="랜덤 배정" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnRandomAllocation_Click"/>
                                <Button x:Name="BtnSeatFixMode" Content="좌석 고정 모드" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnSeatFixMode_Click"/>
                                <Button x:Name="BtnSeatDeleteMode" Content="좌석 데이터 삭제" Style="{StaticResource ActionBarBtn}" Click="BtnSeatDeleteMode_Click"/>
                                <Button x:Name="BtnDeleteSelected" Content="선택된 좌석 삭제" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" Margin="8,0,0,0" Visibility="Collapsed" Click="BtnDeleteSelected_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Grid of Seats -->
                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15">
                                <Grid x:Name="SeatGridContainer">
                                    <!-- Dynamic seat UI will be constructed here code-behind matching the screenshot layout -->
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </Grid>

                    <!-- Right Memo Sidebar -->
                    <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1,0,0,0" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="메모" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                            <!-- Memo List -->
                            <ListBox Grid.Row="1" x:Name="LstMemos" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="🔵 " Foreground="#2563EB" VerticalAlignment="Center" Grid.Column="0"/>
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="12" Foreground="#374151" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Button Content="✎" Foreground="#2563EB" Background="Transparent" BorderThickness="0"
                                                        FontWeight="Bold" Grid.Column="2" Cursor="Hand" Click="BtnEditMemo_Click" CommandParameter="{Binding}" Margin="0,0,4,0"/>
                                                <Button Content="✕" Foreground="#EF4444" Background="Transparent" BorderThickness="0"
                                                        FontWeight="Bold" Grid.Column="3" Cursor="Hand" Click="BtnDeleteMemo_Click" CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Add Memo Input -->
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <TextBox x:Name="TxtNewMemo" Height="60" TextWrapping="Wrap" AcceptsReturn="True" 
                                         BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,8" Padding="5"/>
                                <Button x:Name="BtnAddMemo" Content="+ 메모 추가" Background="#2563EB" Foreground="White" BorderThickness="0" 
                                        Padding="0,8" FontWeight="Bold" Cursor="Hand" Click="BtnAddMemo_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ================= TAB 2: EQUIPMENT STATUS ================= -->
                <Grid x:Name="TabEquipment" Visibility="Collapsed" Background="#F9FAFB" Margin="20">
                    <Grid.RowDefinitions>
                        <!-- Top Alert Card & Action Buttons -->
                        <RowDefinition Height="Auto"/>
                        <!-- Spacer -->
                        <RowDefinition Height="10"/>
                        <!-- Section 1: 기자재 신청 현황 (구글폼) -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                        <!-- Spacer -->
                        <RowDefinition Height="15"/>
                        <!-- Section 2: 기자재 대여 현황 -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Bar: Alert & Actions -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Alert Card -->
                        <Border Grid.Column="0" Background="#FFEDD5" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="8" Padding="12,6" Cursor="Hand" MouseDown="AlertEquipment_MouseDown">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🕒" FontSize="18" Foreground="#EA580C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="기자재 승인 대기" FontSize="10" Foreground="#9A3412" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtEquipmentPendingCount" Text="7건" FontSize="12" Foreground="#EA580C" FontWeight="Bold"/>
                                    <TextBlock Text="빠른 확인 필요" FontSize="9" Foreground="#9A3412"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnUndoReturn" Content="↩️ 되돌리기" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnUndoReturn_Click"/>
                            <Button x:Name="BtnEquipmentDelete" Content="기자재 데이터 삭제" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnEquipmentDelete_Click"/>
                            <Button x:Name="BtnEquipmentFix" Content="기자재 데이터 고정" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnEquipmentFix_Click"/>
                            <Button x:Name="BtnEquipmentExport" Content="기자재 데이터 추출" Style="{StaticResource ActionBarBtn}" Click="BtnEquipmentExport_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Section 1 Header -->
                    <TextBlock Grid.Row="2" Text="기자재 신청 현황 (구글폼)" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10"/>

                    <!-- Section 1 DataGrid -->
                    <Border Grid.Row="3" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10">
                        <DataGrid x:Name="GridEquipmentApprovals" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="40" BorderThickness="0" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="신청 일자" Binding="{Binding RequestDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="학번" Binding="{Binding StudentId}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="이름" Binding="{Binding StudentName}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="소속" Binding="{Binding Department}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="지도교수" Binding="{Binding Advisor}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="승인 처리" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="승인" Background="#10B981" Foreground="White" BorderThickness="0" Padding="12,4" FontWeight="Bold" Margin="0,0,8,0" Click="BtnApproveRequest_Click" CommandParameter="{Binding}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                    </Button.Resources>
                                                </Button>
                                                <Button Content="반려" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="12,4" FontWeight="Bold" Click="BtnRejectRequest_Click" CommandParameter="{Binding}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                    </Button.Resources>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Section 2 Header & Counters -->
                    <Grid Grid.Row="5" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="기자재 대여 현황" FontSize="16" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border BorderBrush="#D1D5DB" BorderThickness="1.5" CornerRadius="6" Background="White" Padding="15,6" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="사용 가능한 기자재 : " FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                                    <TextBlock x:Name="TxtAvailableEquipmentCount" Text="00개" FontSize="12" FontWeight="Bold" Foreground="#2563EB"/>
                                </StackPanel>
                            </Border>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1.5" CornerRadius="6" Background="White" Padding="15,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="사용 중인 기자재 : " FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                                    <TextBlock x:Name="TxtRentedEquipmentCount" Text="00개" FontSize="12" FontWeight="Bold" Foreground="#2563EB"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Section 2 DataGrid -->
                    <Border Grid.Row="6" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10">
                        <DataGrid x:Name="GridRentals" AutoGenerateColumns="False" CanUserAddRows="False" 
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="40"
                                  BorderThickness="0" Background="Transparent" AlternatingRowBackground="#F9FAFB">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="상태" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#10B981"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                <Setter Property="Fill" Value="#EF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="대여자 이름" Binding="{Binding StudentName}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="대여 기자재 종류" Binding="{Binding EquipmentType}" Width="250" IsReadOnly="True"/>
                                <DataGridTextColumn Header="대여 일자" Binding="{Binding RentalDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="반납 기한" Binding="{Binding DueDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="150" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="작업" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="반납완료" Background="#EF4444" Foreground="White" BorderThickness="0" 
                                                    Padding="12,4" FontWeight="Bold" HorizontalAlignment="Left" Cursor="Hand"
                                                    Click="BtnReturnEquipment_Click" CommandParameter="{Binding}">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <!-- ================= TAB 3: CABINET STATUS ================= -->
                <Grid x:Name="TabCabinet" Visibility="Collapsed" Background="#F9FAFB" Margin="20">
                    <Grid.RowDefinitions>
                        <!-- Top Alert Card & Action Buttons -->
                        <RowDefinition Height="Auto"/>
                        <!-- Spacer -->
                        <RowDefinition Height="10"/>
                        <!-- Section 1: 캐비닛 신청 현황 (구글폼) -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="160"/>
                        <!-- Spacer -->
                        <RowDefinition Height="15"/>
                        <!-- Section 2: 캐비닛 배치도 및 현황 -->
                        <RowDefinition Height="*"/>
                        <!-- Bottom Status Counters -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top Bar: Alert & Actions -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Alert Card -->
                        <Border Grid.Column="0" Background="#FFEDD5" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="8" Padding="12,6" Cursor="Hand" MouseDown="AlertEquipment_MouseDown">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🕒" FontSize="18" Foreground="#EA580C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="캐비닛 승인 대기" FontSize="10" Foreground="#9A3412" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtCabinetPendingCount" Text="7건" FontSize="12" Foreground="#EA580C" FontWeight="Bold"/>
                                    <TextBlock Text="빠른 확인 필요" FontSize="9" Foreground="#9A3412"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnCabinetDelete" Content="캐비닛 데이터 삭제" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnCabinetDelete_Click"/>
                            <Button x:Name="BtnCabinetFix" Content="캐비닛 데이터 고정" Style="{StaticResource ActionBarBtn}" Margin="0,0,8,0" Click="BtnCabinetFix_Click"/>
                            <Button x:Name="BtnCabinetExport" Content="캐비닛 데이터 추출" Style="{StaticResource ActionBarBtn}" Click="BtnCabinetExport_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Section 1 Header -->
                    <TextBlock Grid.Row="2" Text="캐비닛 신청 현황 (구글폼)" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10"/>

                    <!-- Section 1 DataGrid -->
                    <Border Grid.Row="3" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10">
                        <DataGrid x:Name="GridCabinetApprovals" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="40" BorderThickness="0" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="신청 일자" Binding="{Binding RequestDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="130" IsReadOnly="True"/>
                                <DataGridTextColumn Header="학번" Binding="{Binding StudentId}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="이름" Binding="{Binding StudentName}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="소속" Binding="{Binding Department}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="지도교수" Binding="{Binding Advisor}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="승인 처리" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="승인" Background="#10B981" Foreground="White" BorderThickness="0" Padding="12,4" FontWeight="Bold" Margin="0,0,8,0" Click="BtnApproveRequest_Click" CommandParameter="{Binding}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                    </Button.Resources>
                                                </Button>
                                                <Button Content="반려" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="12,4" FontWeight="Bold" Click="BtnRejectRequest_Click" CommandParameter="{Binding}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                                                    </Button.Resources>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Section 2: Cabinet Layout -->
                    <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,10,0,10">
                        <StackPanel HorizontalAlignment="Center">
                            <!-- Upper Cabinet Block (1-24) -->
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" Background="White" Padding="10" CornerRadius="8" Margin="0,0,0,15">
                                <UniformGrid x:Name="GridCabinetBlock1" Columns="8" Rows="3" Width="720" Height="220"/>
                            </Border>

                            <!-- Lower Cabinet Block (25-48) -->
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" Background="White" Padding="10" CornerRadius="8">
                                <UniformGrid x:Name="GridCabinetBlock2" Columns="8" Rows="3" Width="720" Height="220"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Bottom Status Counters -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Border BorderBrush="#D1D5DB" BorderThickness="1.5" CornerRadius="6" Background="White" Padding="15,6" Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="사용 가능한 캐비닛 : " FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                                <TextBlock x:Name="TxtAvailableCabinetCount" Text="00개" FontSize="12" FontWeight="Bold" Foreground="#2563EB"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#D1D5DB" BorderThickness="1.5" CornerRadius="6" Background="White" Padding="15,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="사용 중인 캐비닛 : " FontSize="12" FontWeight="SemiBold" Foreground="#374151"/>
                                <TextBlock x:Name="TxtRentedCabinetCount" Text="00개" FontSize="12" FontWeight="Bold" Foreground="#2563EB"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ================= TAB 4: SANGSANGLAB APPROVAL ================= -->
                <Grid x:Name="TabSangsangLab" Visibility="Collapsed" Background="#F9FAFB" Margin="20">
                    <Grid.RowDefinitions>
                        <!-- Top Alert Card -->
                        <RowDefinition Height="Auto"/>
                        <!-- Spacer -->
                        <RowDefinition Height="15"/>
                        <!-- Section Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Cards Container -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Bar: Alert -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Alert Card -->
                        <Border Grid.Column="0" Background="#FFEDD5" BorderBrush="#FED7AA" BorderThickness="1" CornerRadius="8" Padding="12,6" Cursor="Hand" MouseDown="AlertEquipment_MouseDown">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🕒" FontSize="18" Foreground="#EA580C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="상상Lab 승인 대기" FontSize="10" Foreground="#9A3412" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtSangsangLabPendingCount" Text="7건" FontSize="12" Foreground="#EA580C" FontWeight="Bold"/>
                                    <TextBlock Text="빠른 확인 필요" FontSize="9" Foreground="#9A3412"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="상상Lab 신청 및 승인 대기 (구글폼)" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,15"/>

                    <!-- Cards ScrollViewer -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LstSangsangLabCards">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="-10"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="300" Height="190" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Margin="10" Padding="18">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#9CA3AF" Opacity="0.15"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Card Header -->
                                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="상상Lab 신청" FontSize="14" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="신규 요청" FontSize="9" FontWeight="Bold" Foreground="#2563EB"/>
                                                </Border>
                                            </Grid>

                                            <!-- Card Content -->
                                            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="👤 신청자" FontSize="11" Foreground="#4B5563" Width="70"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding StudentName}" FontSize="11" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="더보기" Background="Transparent" BorderThickness="0" Foreground="#4B5563" FontSize="10" Cursor="Hand" Click="BtnViewSangsangLabDetails_Click" CommandParameter="{Binding}"/>
                                                </Grid>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="🕒 요청 시간" FontSize="11" Foreground="#4B5563" Width="70"/>
                                                    <TextBlock Text="{Binding RequestDate, StringFormat=\{0:yyyy-MM-dd 14:00 ~ 16:00\}}" FontSize="11" Foreground="#1F2937"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🏢 희망 공간" FontSize="11" Foreground="#4B5563" Width="70"/>
                                                    <TextBlock Text="u301" FontSize="11" FontWeight="Bold" Foreground="#1F2937"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Card Actions -->
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0" Content="✓ 승인" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="0,8" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="BtnApproveRequest_Click" CommandParameter="{Binding}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </Button.Resources>
                                                </Button>

                                                <Button Grid.Column="2" Content="✕ 반려" Background="White" BorderBrush="#EF4444" BorderThickness="1" Foreground="#EF4444" Padding="0,7" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="BtnRejectRequest_Click" CommandParameter="{Binding}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- ================= TAB 5: DATA MANAGEMENT ================= -->
                <Grid x:Name="TabDataManage" Visibility="Collapsed" Background="#F9FAFB" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="데이터 관리 (마스터 데이터베이스)" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="구글 폼 연동 마스터 데이터입니다. 여기서 수정/삭제해도 대시보드의 현재 좌석 데이터가 즉시 손실되지 않습니다." FontSize="12" Foreground="#6B7280" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Student Search Bar -->
                    <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="검색어 (학번/이름/지도교수): " FontSize="13" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtSearchStudent" Width="200" Padding="5" VerticalContentAlignment="Center" KeyUp="TxtSearchStudent_KeyUp" Margin="0,0,10,0"/>
                            <Button Content="🔍 검색" Style="{StaticResource ActionBarBtn}" Padding="15,6" Click="BtnSearchStudent_Click" Margin="0,0,5,0"/>
                            <Button Content="🔄 전체보기" Style="{StaticResource ActionBarBtn}" Padding="15,6" Click="BtnClearStudentSearch_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <!-- Master Student DataGrid -->
                            <DataGrid Grid.Column="0" x:Name="GridMasterStudents" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeight="35" BorderThickness="0" Background="Transparent" SelectionChanged="GridMasterStudents_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="학번" Binding="{Binding StudentId}" Width="100"/>
                                    <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="100"/>
                                    <DataGridTextColumn Header="소속" Binding="{Binding Department}" Width="150"/>
                                    <DataGridTextColumn Header="지도교수" Binding="{Binding Advisor}" Width="100"/>
                                    <DataGridTextColumn Header="이메일" Binding="{Binding Email}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- View/Edit Details Panel -->
                            <Border Grid.Column="1" BorderBrush="#E5E7EB" BorderThickness="1,0,0,0" Margin="15,0,0,0" Padding="15,0,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PanelMasterEdit" IsEnabled="False">
                                        <TextBlock Text="학생 정보 상세" FontSize="14" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,10"/>

                                        <TextBlock Text="학번" FontSize="11" Foreground="#6B7280"/>
                                        <TextBox x:Name="TxtMasterId" Margin="0,2,0,8" Padding="5"/>

                                        <TextBlock Text="이름" FontSize="11" Foreground="#6B7280"/>
                                        <TextBox x:Name="TxtMasterName" Margin="0,2,0,8" Padding="5"/>

                                        <TextBlock Text="소속" FontSize="11" Foreground="#6B7280"/>
                                        <TextBox x:Name="TxtMasterDept" Margin="0,2,0,8" Padding="5"/>

                                        <TextBlock Text="지도교수" FontSize="11" Foreground="#6B7280"/>
                                        <TextBox x:Name="TxtMasterAdvisor" Margin="0,2,0,8" Padding="5"/>

                                        <TextBlock Text="이메일" FontSize="11" Foreground="#6B7280"/>
                                        <TextBox x:Name="TxtMasterEmail" Margin="0,2,0,15" Padding="5"/>

                                        <Button Content="변경 사항 저장" Background="#10B981" Foreground="White" BorderThickness="0" Padding="0,8" FontWeight="Bold" Click="BtnSaveMaster_Click"/>
                                        <Button Content="마스터에서 삭제" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="0,8" FontWeight="Bold" Margin="0,8,0,0" Click="BtnDeleteMaster_Click"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ================= TAB 6: SETTINGS ================= -->
                <Grid x:Name="TabSettings" Visibility="Collapsed" Background="#F9FAFB" Margin="20">
                    <StackPanel>
                        <TextBlock Text="설정" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,15"/>
                        <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="시스템 정보" FontSize="14" FontWeight="Bold" Foreground="#374151" Margin="0,0,0,10"/>
                                <TextBlock Text="프로그램명: 동서대학교 좌석 및 기자재 대여 관리 프로그램" Margin="0,0,0,5"/>
                                <TextBlock Text="버전: v1.0.0" Margin="0,0,0,5"/>
                                <TextBlock Text="플랫폼: .NET 10.0 WPF Application" Margin="0,0,0,15"/>

                                <TextBlock Text="구글 폼 연동 설정" FontSize="14" FontWeight="Bold" Foreground="#374151" Margin="0,15,0,10"/>
                                <TextBlock Text="구글 폼 URL" FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtGoogleFormUrl" Height="35" BorderBrush="#D1D5DB" BorderThickness="1" Padding="10" Margin="0,0,0,15" VerticalAlignment="Center"/>

                                <TextBlock Text="화면 해상도 설정" FontSize="14" FontWeight="Bold" Foreground="#374151" Margin="0,10,0,10"/>
                                <ComboBox x:Name="ComboResolution" Width="200" Padding="5" HorizontalAlignment="Left" Margin="0,0,0,15" SelectedIndex="0" SelectionChanged="ComboResolution_SelectionChanged">
                                    <ComboBoxItem Content="기본 (1200 x 780)"/>
                                    <ComboBoxItem Content="소형 (1024 x 768)"/>
                                    <ComboBoxItem Content="중형 (1440 x 900)"/>
                                    <ComboBoxItem Content="대형 (1920 x 1080)"/>
                                </ComboBox>

                                <TextBlock Text="구글 폼 데이터 동기화 시뮬레이터" FontSize="14" FontWeight="Bold" Foreground="#374151" Margin="0,10,0,10"/>
                                <Button Content="📥 새로운 구글폼 신청 데이터 수신 (시뮬레이션)" HorizontalAlignment="Left" Padding="15,8" Style="{StaticResource ActionBarBtn}" Click="BtnSimulateFormSubmission_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- ================= SEAT DETAIL PANEL / MODAL OVERLAY ================= -->
        <Grid x:Name="ModalSeatDetails" Grid.ColumnSpan="2" Background="#80000000" Visibility="Collapsed">
            <Border Background="White" Width="820" Height="520" CornerRadius="20" Padding="35" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="0" Color="Black" Opacity="0.25"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Hidden elements for compilation compatibility -->
                    <TextBlock x:Name="TxtModalSeatNum" Visibility="Collapsed"/>
                    <ItemsControl x:Name="ItemsModalAttendance" Visibility="Collapsed"/>

                    <!-- Close button in top-right, Info edit button nearby -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="10" Margin="0,-15,0,0">
                        <Button x:Name="BtnEditStudentInfo" Content="정보 수정" Background="#F3F4F6" Foreground="#374151" BorderThickness="0" Padding="15,6" FontSize="12" FontWeight="SemiBold" Cursor="Hand" Click="BtnEditStudentInfo_Click" Margin="0,0,15,0">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="BtnCloseModal" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnCloseModal_Click" Padding="5">
                            <TextBlock Text="🚪" FontSize="24" Foreground="#111827"/>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="0" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <!-- Student Profile info -->
                            <RowDefinition Height="Auto"/>
                            <!-- Divider or space -->
                            <RowDefinition Height="20"/>
                            <!-- Bottom half: stats & chart -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Student Profile -->
                        <Grid Grid.Row="0" Margin="20,10,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Column 1 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="이름 : " FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtModalName" Text="홍길동" FontSize="20" FontWeight="Bold" Foreground="Black" BorderThickness="0" Background="Transparent" IsReadOnly="True" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="지도 교수 : " FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtModalAdvisor" Text="김선용" FontSize="20" FontWeight="Bold" Foreground="Black" BorderThickness="0" Background="Transparent" IsReadOnly="True" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="이메일 : " FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtModalEmail" Text="gildong123@naver.com" FontSize="20" FontWeight="Bold" Foreground="Black" BorderThickness="0" Background="Transparent" IsReadOnly="True" VerticalAlignment="Center" Width="300"/>
                            </StackPanel>

                            <!-- Column 2 -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="소속 : " FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtModalDept" Text="소프트웨어 전공" FontSize="20" FontWeight="Bold" Foreground="Black" BorderThickness="0" Background="Transparent" IsReadOnly="True" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="학번 : " FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtModalId" Text="20261234" FontSize="20" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Bottom half -->
                        <Grid Grid.Row="2" Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Attendance stats -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="10,0,20,0">
                                <TextBlock Text="• 출석 데이터 (분 기준)" FontSize="18" FontWeight="Bold" Foreground="Black" Margin="0,0,0,25"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="정상 근무 시간 (누적) = " FontSize="16" FontWeight="Bold" Foreground="#374151"/>
                                    <TextBlock x:Name="TxtNormalWorkTime" Text="00:00" FontSize="16" FontWeight="Bold" Foreground="#6366F1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="최근 출근 날짜/시간 = " FontSize="16" FontWeight="Bold" Foreground="#374151"/>
                                    <TextBlock x:Name="TxtLastCheckIn" Text="00:00" FontSize="16" FontWeight="Bold" Foreground="#6366F1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="최근 퇴근 시간 = " FontSize="16" FontWeight="Bold" Foreground="#374151"/>
                                    <TextBlock x:Name="TxtLastCheckOut" Text="00:00" FontSize="16" FontWeight="Bold" Foreground="#6366F1"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right: Chart placeholder -->
                            <Border Grid.Column="1" BorderBrush="Black" BorderThickness="1.5" Background="White" Padding="15,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Title -->
                                    <TextBlock x:Name="TxtChartTitle" Text="‘학생 이름’ 일별 출석 시간" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#374151"/>

                                    <!-- Chart Visual representation -->
                                    <Grid Grid.Row="1" Height="180">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <UniformGrid Grid.Column="0" Columns="1" Rows="11" VerticalAlignment="Stretch" Margin="0,0,8,0">
                                            <TextBlock Text="500" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="450" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="400" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="350" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="300" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="250" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="200" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="150" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="100" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="50" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                            <TextBlock Text="0" FontSize="8" Foreground="#6B7280" TextAlignment="Right"/>
                                        </UniformGrid>

                                        <Grid Grid.Column="1">
                                            <UniformGrid Columns="1" Rows="10" VerticalAlignment="Stretch">
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1"/>
                                            </UniformGrid>

                                            <UniformGrid Columns="7" Rows="1" VerticalAlignment="Bottom" Height="170" Margin="5,0">
                                                <Border Background="#1E3A8A" CornerRadius="1,1,0,0" Height="70" VerticalAlignment="Bottom" Margin="4,0"/>
                                                <Border Background="#F97316" CornerRadius="1,1,0,0" Height="85" VerticalAlignment="Bottom" Margin="4,0"/>
                                                <Border Background="#15803D" CornerRadius="1,1,0,0" Height="20" VerticalAlignment="Bottom" Margin="4,0"/>
                                                <Border Background="#06B6D4" CornerRadius="1,1,0,0" Height="28" VerticalAlignment="Bottom" Margin="4,0"/>
                                                <Border Background="#A855F7" CornerRadius="1,1,0,0" Height="150" VerticalAlignment="Bottom" Margin="4,0"/>
                                                <Border Background="#22C55E" CornerRadius="1,1,0,0" Height="17" VerticalAlignment="Bottom" Margin="4,0"/>
                                                <Border Background="#1E293B" CornerRadius="1,1,0,0" Height="7" VerticalAlignment="Bottom" Margin="4,0"/>
                                            </UniformGrid>
                                        </Grid>
                                    </Grid>

                                    <UniformGrid Grid.Row="2" Columns="7" Rows="1" Margin="30,5,5,0">
                                        <TextBlock Text="월" FontSize="8" Foreground="#374151" HorizontalAlignment="Center"/>
                                        <TextBlock Text="화" FontSize="8" Foreground="#374151" HorizontalAlignment="Center"/>
                                        <TextBlock Text="수" FontSize="8" Foreground="#374151" HorizontalAlignment="Center"/>
                                        <TextBlock Text="목" FontSize="8" Foreground="#374151" HorizontalAlignment="Center"/>
                                        <TextBlock Text="금" FontSize="8" Foreground="#374151" HorizontalAlignment="Center"/>
                                        <TextBlock Text="토" FontSize="8" Foreground="#374151" HorizontalAlignment="Center"/>
                                        <TextBlock Text="일" FontSize="8" Foreground="#374151" HorizontalAlignment="Center"/>
                                    </UniformGrid>

                                    <TextBlock Grid.Row="3" Text="이번주 이용시간 (분)" FontSize="8" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Footer Action buttons -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button x:Name="BtnEditStudentModal" Content="수정" Background="#10B981" Foreground="White" BorderThickness="0" Padding="20,8" FontWeight="Bold" Margin="0,0,8,0" Cursor="Hand" Click="BtnEditStudentModal_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="확인" Background="#2563EB" Foreground="White" BorderThickness="0" Padding="20,8" FontWeight="Bold" Cursor="Hand" Click="BtnCloseModal_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
